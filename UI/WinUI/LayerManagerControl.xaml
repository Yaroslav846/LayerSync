<UserControl
    x:Class="LayerSync.UI.WinUI.LayerManagerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:vm="using:LayerSync.UI.ViewModels"
    xmlns:local="using:LayerSync.UI.WinUI"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search Layers..." Margin="0,0,0,15"/>

        <Border Grid.Row="1" Margin="0,0,0,10"
                BorderThickness="1" BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" CornerRadius="4"
                Visibility="{Binding IsNewLayerModeActive, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Margin="10" Spacing="10">
                <TextBox Text="{Binding NewLayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="200" PlaceholderText="New Layer Name"/>
                <Button Content="Create" Command="{Binding CreateLayerCommand}"/>
                <Button Content="Cancel" Command="{Binding CancelNewLayerCommand}" Style="{ThemeResource AccentButtonStyle}"/>
            </StackPanel>
        </Border>

        <controls:DataGrid
            Grid.Row="2"
            x:Name="LayersDataGrid"
            ItemsSource="{Binding Layers}"
            SelectedItem="{Binding SelectedLayer, Mode=TwoWay}"
            SelectionMode="Extended"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            GridLinesVisibility="Horizontal"
            SelectionChanged="LayersDataGrid_SelectionChanged">
            <controls:DataGrid.Columns>
                <controls:DataGridTemplateColumn Header="Current" Width="SizeToCells">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:LayerItemViewModel">
                            <TextBlock Text="✓"
                                       Visibility="{Binding IsCurrent, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource SystemAccentColor}"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <controls:DataGridTemplateColumn Header="Color" Width="SizeToCells">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:LayerItemViewModel">
                            <Rectangle Width="25" Height="15"
                                       Fill="{Binding DisplayBrush}"
                                       Stroke="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                                       StrokeThickness="1"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTemplateColumn Header="On">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:LayerItemViewModel">
                            <CheckBox IsChecked="{Binding IsOn}" HorizontalAlignment="Center" Click="OnCheckBox_Click"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTemplateColumn Header="Frozen">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:LayerItemViewModel">
                            <CheckBox IsChecked="{Binding IsFrozen}" HorizontalAlignment="Center" Click="FrozenCheckBox_Click"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTextColumn Header="Count" Binding="{Binding ObjectCount}" />
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <CommandBar Grid.Row="3" DefaultLabelPosition="Right">
            <AppBarButton Icon="Add" Label="New" Command="{Binding NewLayerCommand}" />
            <AppBarButton Icon="Delete" Label="Delete" Command="{Binding DeleteLayersCommand}" />
            <AppBarSeparator/>
            <AppBarButton Icon="Accept" Label="Set Current" Command="{Binding SetCurrentCommand}" />
            <AppBarButton Icon="MoveTo" Label="Move Selection" Command="{Binding MoveSelectionToLayerCommand}" />
            <AppBarSeparator/>
            <AppBarButton Icon="Color" Label="Change Color" Command="{Binding ChangeColorCommand}" />
            <AppBarButton Icon="SelectAll" Label="Select by Color" Command="{Binding SelectByColorCommand}" />
            <AppBarSeparator/>
            <AppBarButton Icon="Refresh" Label="Refresh" Command="{Binding RefreshCommand}" />
            <AppBarSeparator/>
            <AppBarButton Icon="Switch" Label="Toggle Theme" Command="{Binding ToggleThemeCommand}" />
        </CommandBar>
    </Grid>
</UserControl>
